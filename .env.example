# Infrastructure — set in Vercel Dashboard
# All values are present in Vercel env vars as of Phase 1 setup

# Turso database
TURSO_DATABASE_URL=libsql://thehoecks-xxx.turso.io
TURSO_AUTH_TOKEN=              # from Turso dashboard

# Cloudflare R2
R2_ACCOUNT_ID=                 # from Cloudflare dashboard
R2_ACCESS_KEY_ID=              # from R2 API token
R2_SECRET_ACCESS_KEY=          # from R2 API token
R2_BUCKET_NAME=thehoecks-media
R2_PUBLIC_URL=                 # https://pub-xxx.r2.dev (public bucket URL)

# Auth
JWT_SECRET=                    # random 64-char hex string (openssl rand -hex 32)
ADMIN_PASSWORD=                # admin panel password
ADMIN_API_TOKEN=               # random token for API/iOS Shortcut auth (openssl rand -hex 32) — NEEDS TO BE ADDED
VIEWER_PASSWORD=               # shared family password (used by /api/init to seed bcrypt hash)

# Site
NEXT_PUBLIC_SITE_URL=https://thehoecks.com

# Vision enrichment (compose-time date/tag suggestions + search captions).
# Optional — without a key the upload/edit pages silently skip the feature.
ANTHROPIC_API_KEY=             # from console.anthropic.com
ENRICH_MODEL=                  # optional override; defaults to claude-haiku-4-5

# Web Push notifications (daily "On this day" memories)
VAPID_PUBLIC_KEY=              # from `npx web-push generate-vapid-keys`
VAPID_PRIVATE_KEY=            # keep secret — never commit
VAPID_SUBJECT=mailto:admin@thehoecks.com   # contact for push services
CRON_SECRET=                  # random token; also set as a GitHub Actions secret

# GitHub Actions secrets (repo Settings → Secrets → Actions), for the
# hourly daily-memories workflow:
#   SITE_URL     = https://thehoecks.com
#   CRON_SECRET  = same value as the CRON_SECRET above

# ── Backups (GitHub Actions) ────────────────────────────────────
# Daily backup.yml workflow: dumps Turso → gzip → private R2 bucket, prunes
# to the most recent 30. NEVER the public thehoecks-media bucket.
R2_BACKUP_BUCKET=thehoecks-backups   # separate, PRIVATE R2 bucket (public access OFF)

# GitHub Actions secrets (repo Settings → Secrets → Actions) required by
# .github/workflows/backup.yml:
#   TURSO_DATABASE_URL   = same as above
#   TURSO_AUTH_TOKEN     = same as above
#   R2_ACCOUNT_ID        = same as above
#   R2_ACCESS_KEY_ID     = same as above (R2 API token must have write access
#                          to the thehoecks-backups bucket)
#   R2_SECRET_ACCESS_KEY = same as above
#   R2_BACKUP_BUCKET     = thehoecks-backups

# Migration (only needed for scripts/migrate.ts)
TUMBLR_OAUTH_CONSUMER_KEY=       # Tumblr OAuth Consumer Key (from tumblr.com/oauth/apps)
TUMBLR_OAUTH_CONSUMER_SECRET=    # Tumblr OAuth Consumer Secret (not currently used, kept for reference)


# ── Status of Vercel env vars ──────────────────────────────────
# ✅ TURSO_DATABASE_URL        — set
# ✅ TURSO_AUTH_TOKEN           — set
# ✅ R2_ACCOUNT_ID              — set
# ✅ R2_ACCESS_KEY_ID           — set
# ✅ R2_SECRET_ACCESS_KEY       — set
# ✅ R2_BUCKET_NAME             — set
# ✅ R2_PUBLIC_URL              — set
# ✅ JWT_SECRET                 — set
# ✅ ADMIN_PASSWORD             — set
# ✅ VIEWER_PASSWORD            — set
# ❌ ADMIN_API_TOKEN            — MISSING, needs to be added
# ❌ NEXT_PUBLIC_SITE_URL       — MISSING, should add
